# Copy to .env (gitignored) and fill in. Never commit real values.

# Frontend
NEXT_PUBLIC_API_BASE_URL=

# Backend — OpenAI / ChatGPT powers résumé extraction.
# Leave OPENAI_API_KEY blank to run in offline demo mode (keyword extractor).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
DATABASE_URL=sqlite+aiosqlite:///./isobar.db
STORAGE_DIR=uploads
DEBUG=false
SEED_DEMO_JOBS=true
